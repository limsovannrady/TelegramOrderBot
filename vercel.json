{
  "version": 2,
  "installCommand": "pip install --no-cache-dir --upgrade -r requirements.txt",
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    },
    {
      "src": "/api/ping",
      "dest": "/api/ping.py"
    }
  ]
}
