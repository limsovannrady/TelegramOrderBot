modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vercel Webhook Mode"

[[workflows.workflow]]
name = "Vercel Webhook Mode"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -c \"import time; print('Vercel webhook mode active. Local polling disabled.', flush=True); time.sleep(31536000)\""

[workflows.workflow.metadata]
outputType = "console"

[agent]
expertMode = true

[deployment]
deploymentTarget = "vm"
run = ["python", "telegram_bot_simple.py"]

[userenv]

[userenv.shared]
TELEGRAM_CHANNEL_ID = "-1003756077815"
